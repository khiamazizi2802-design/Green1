rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(email) {
      return isAuthenticated() && request.auth.token.email.lower() == email.lower();
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.token.email.lower())).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.token.email.lower())) &&
        getUserData().role == 'super_admin';
    }

    // Users Collection rules
    match /users/{email} {
      allow read: if isAuthenticated();
      allow create, delete: if isOwner(email) || isAdmin();
      allow update: if isOwner(email) || isAdmin() || (
        isAuthenticated() &&
        getUserData().role == 'manager' &&
        (resource.data.role == 'driver' || resource.data.role == 'staff') &&
        (resource.data.onboarded == false || resource.data.managerId == request.auth.token.email.lower())
      );
      
      // Subcollection: paymentMethods
      match /paymentMethods/{methodId} {
        allow read, write: if isOwner(email) || isAdmin();
      }

      // Subcollection: posts
      match /posts/{postId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(email) || isAdmin();
      }
    }

    // Pending Staff Collection rules
    match /pending_staff/{staffId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (
        isOwner(resource.data.email) || 
        isOwner(resource.data.managerId) || 
        isAdmin() ||
        (getUserData().role == 'manager' && (resource.data.onboarded == false || resource.data.managerId == request.auth.token.email.lower()))
      );
    }

    // Business Menus Collection rules
    match /business_menus/{email} {
      // Anyone can read menus to order food/items
      allow read: if isAuthenticated();
      // Only the business owner (manager) or admin can write
      allow write: if isOwner(email) || isAdmin();
    }

    // Vehicles Collection rules
    match /vehicles/{vehicleId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (
        getUserData().role == 'manager' || 
        getUserData().role == 'driver' || 
        isAdmin()
      );
    }

    // Global System Settings & Policies rules
    match /system_config/{configId} {
      allow read: if true;
      allow write: if isAuthenticated() && (getUserData().role == 'super_admin' || isAdmin());
    }
  }
}
